{
  "name": "__MSG_appName__",
  "description": "__MSG_shortDesc__",
  "default_locale": "en",
  "version": "1.2.1",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PDF Text to Speech",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "*://*/*.pdf",
    "*://*/*.PDF",
    "file:///*",
    "https://pdftext2speech.com/*",
    "https://www.pdftext2speech.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*.pdf",
        "*://*/*.PDF",
        "file:///*"
      ],
      "js": [
        "vendor/pdfjs/pdf.min.js",
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/pdfjs/pdf.worker.min.js",
        "paywall.html",
        "paywall.js"
      ],
      "matches": [
        "<all_urls>",
        "https://pdftext2speech.com/*",
        "https://www.pdftext2speech.com/*"
      ]
    }
  ]
}
